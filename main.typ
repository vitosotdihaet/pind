=== Описание условных обозначений
Диаграмма выполнена в нотации Чена @chen. Используемые обозначения:
- прямоугольник --- сущность;
- ромб --- связь;
- овал --- атрибут сущности;
- 1:1 --- связь "один к одному";
- 1:N --- связь "один ко многим".

// Нотация описана в работе P. P. Chen "The Entity-Relationship Model --- Toward a Unified View of Data" (1976) @chen.

=== Описание сущностей
#let entity(term, definition, attributes: (), last: false) = {
  let last_text = if last [.] else [;]

  let attribute_text = if attributes.len() > 0 [. Атрибуты:
    #for (i, attr) in attributes.enumerate() [
      #if attr.len() <= 1 [
        - #attr.at(0)#if i == attributes.len() - 1 [#last_text] else [;]
      ] else [
        - #attr.at(0) --- #attr.at(1)#if i == attributes.len() - 1 [#last_text] else [;]
      ]
    ]
  ] else [#last_text]
  [
    - #term --- #definition#attribute_text
  ]
}

